# App (Next.js) — public, safe to expose in the browser bundle
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# App base URL. Used by /api/trigger-fetch to call the internal cron route
# and by the OAuth callback. Set to your deployed origin in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Server-only secrets (never expose to the browser) -----

# Used by /api/cron/fetch-emails to write to the database with the admin role.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google OAuth client (same credentials configured in Supabase Auth → Google).
# Used by /api/cron/fetch-emails to refresh each user's Gmail access token.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Gemini API key for statement parsing inside /api/cron/fetch-emails.
GEMINI_API_KEY=your-gemini-api-key

# Shared bearer token that pg_cron sends to /api/cron/fetch-emails.
# Must match the `cron_secret` value stored in Supabase Vault.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-long-random-cron-secret
